*.py[cod]
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Local caches
.cache/
.ipynb_checkpoints/

# Environment / local config
.env
.env.*
.python-version

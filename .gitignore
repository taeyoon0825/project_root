!artifacts/**/*.json
!artifacts/**/*.npy
!artifacts/**/*.faiss
!artifacts/**/*.joblib

# Large model / index / binary artifacts
*.pt
*.bin
*.safetensors
*.npy
*.npz
*.faiss
*.joblib

# Media outputs
*.wav
*.mp3
*.m4a
*.flac
*.mp4
*.mov
*.mkv
*.avi
*.webm

# Final allow-list for Streamlit deployment assets
!data/metadata/
!data/metadata/*.csv
!artifacts/
!artifacts/embeddings/
!artifacts/indices/
!artifacts/plots/
!artifacts/clusters/
!artifacts/evaluation/

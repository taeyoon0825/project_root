# Generated datasets and audio outputs
data/raw/
data/processed/
data/audio/

# Keep deployment metadata tracked
!data/metadata/
!data/metadata/*.csv

# Keep deployment artifacts tracked
!artifacts/
!artifacts/embeddings/
!artifacts/indices/
!artifacts/plots/
!artifacts/clusters/
!artifacts/evaluation/
